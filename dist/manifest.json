{
  "manifest_version": 3,
  "name": "Testportal Stealth Helper",
  "description": "Stealth extension for Testportal. Extract questions and type answers stealthily.",
  "version": "1.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Set API Key"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "focus.js",
        "assets/chunk-CnxtX0uT.js",
        "assets/config-DSlncnU2.js",
        "assets/content.ts-BW6JA0qJ.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-BkQOSmIm.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
